{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "devCommand": "next dev",
  "installCommand": "yarn install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/cleanup-pending",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-pending-tenants",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/lifecycle-sweep",
      "schedule": "0 3 * * *"
    }
  ]
}
