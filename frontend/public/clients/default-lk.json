  "defaultLocale": "no",

  "brand": {
    "name": "Ko | Do · Vault",
    "tagline": "Din digitale nøkkelring"
  },

  "rotate": "session",
  "bgImageOverlay": 0.10,
  "backdropBlurChrome": "24px",
  "backdropBlurSafari": "48px",
  "cardBgChrome": "rgba(255, 255, 255, 0.10)",
  "cardBgSafari": "rgba(30, 41, 59, 0.90)",
  "mobileSolidBackground": false,
  "mobileSolidColor": "#1A1A1A",

  "categories": [
    { "key": "personal", "label": "Personlig", "color": "#4ade80", "icon": "🏠" },
    { "key": "work",     "label": "Jobb",      "color": "#60a5fa", "icon": "💼" },
    { "key": "bank",     "label": "Bank",      "color": "#f59e0b", "icon": "🏦" },
    { "key": "social",   "label": "Sosial",    "color": "#a78bfa", "icon": "👥" },
    { "key": "mail",     "label": "Mail",      "color": "#f87171", "icon": "✉️" },
    { "key": "tv",       "label": "TV",        "color": "#fb923c", "icon": "📺" },
    { "key": "webserv",  "label": "WEB Serv.", "color": "#22d3ee", "icon": "☁️" },
    { "key": "other",    "label": "Annet",     "color": "#94a3b8", "icon": "📁" }
  ],

  "security": {
    "autoLockMinutes": 15,
    "forceMasterAfterDays": 14,
    "clipboardClearSeconds": 120,
    "clipboardEnabled": true,
    "loginHistoryCount": 15
  },

  "image": {
    "maxWidth": 1200,
    "maxHeight": 750,
    "quality": 0.75,
    "format": "image/jpeg"
  },

  "ui": {
    "defaultSort": "favorite",
    "showFavoritesFirst": true,
    "dateLocale": "nb-NO",
    "passwordsViewMode": "grouped",
    "cardsViewMode": "list"
  },

  "features": {
    "packages": {
      "showOnLogin": true,
      "showInApp": true,
      "maxFileSizeMB": 50,
      "allowedMimeTypes": null
    },
    "ids": {
      "enabled": true,
      "showInApp": true
    }
  },

